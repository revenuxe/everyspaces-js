# Next.js (public)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-01-01

# Server-only (never expose to the browser)
SANITY_API_READ_TOKEN=

# Sanity Studio (npm run sanity dev) — duplicate NEXT_PUBLIC_* if you only set one set
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# Studio in the browser (Vite): optional duplicates — Sanity project id is public
# If Studio still says "Missing project ID", add these lines (same values as above).
VITE_SANITY_STUDIO_PROJECT_ID=
VITE_SANITY_STUDIO_DATASET=production

# Basic auth for /studio in production (middleware)
SANITY_STUDIO_BASIC_USER=admin
SANITY_STUDIO_BASIC_PASS=change-me
